        "overrides": []
      },
      "gridPos": {
        "h": 11,
        "w": 8,
        "x": 16,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "sum"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "editorMode": "code",
          "expr": "sum by (process) (count_over_time({job=~\"thechat-api|thechat-hermes-gateway|thechat-desktop\",process=~\"$process\"} |~ \"(?i)(warn|warning|error|fatal|panic|exception|failed)\" |~ \"$search\" [$__interval]))",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Warnings/errors over time",
      "type": "timeseries"
    },
