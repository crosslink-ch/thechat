{
  "name": "thechat-monorepo",
  "private": true,
  "scripts": {
    "dev": "python3 scripts/dev.py",
    "dev:services": "python3 scripts/dev.py",
    "dev:desktop": "pnpm --filter @thechat/desktop dev",
    "dev:api": "pnpm --filter @thechat/api dev",
    "dev:worker": "pnpm --filter @thechat/api dev:worker",
    "dev:hermes": "scripts/run-hermes-manual.sh",
    "dev:hermes-progress-demo": "node scripts/hermes-progress-demo.mjs",
    "build": "pnpm -r build",
    "build:desktop": "pnpm --filter @thechat/desktop build",
    "build:api": "pnpm --filter @thechat/api build",
    "test": "python3 scripts/test.py",
    "test:desktop": "pnpm --filter @thechat/desktop test",
    "test:api": "pnpm --filter @thechat/api test",
    "test:kafka": "pnpm --filter @thechat/api test:kafka",
    "tauri": "dotenv -- pnpm --filter @thechat/desktop tauri",
    "tauri:dev": "dotenv -- pnpm --filter @thechat/desktop tauri dev",
    "tauri:build": "dotenv -- pnpm --filter @thechat/desktop tauri build",
    "db:generate": "pnpm --filter @thechat/api db:generate",
    "db:migrate": "pnpm --filter @thechat/api db:migrate",
    "db:push": "pnpm --filter @thechat/api db:push",
    "db:studio": "pnpm --filter @thechat/api db:studio",
    "test:e2e": "pnpm --filter @thechat/desktop test:e2e",
    "test:e2e:headless": "pnpm --filter @thechat/desktop test:e2e:headless",
    "test:e2e:hermes": "python3 scripts/e2e/hermes-bot-flow.py"
  },
  "packageManager": "pnpm@10.28.2",
  "devDependencies": {
    "dotenv-cli": "^11.0.0"
  },
  "pnpm": {
    "patchedDependencies": {
      "kafkajs@2.2.4": "patches/kafkajs@2.2.4.patch"
    }
  }
}
