DATABASE_URL=postgresql://thechat:thechat@localhost:15543/thechat
REDIS_URL=redis://localhost:16380
REDIS_KEY_PREFIX=thechat

# Realtime websocket fanout. Use redis for multi-pod deployments.
# local keeps delivery in-process for development without Redis.
REALTIME_DRIVER=redis

# Async job queue foundation for workers/bots.
ASYNC_WORKER_CONCURRENCY=4

# Domain events. The API only writes the transactional Postgres outbox; the
# worker either handles it directly (outbox) or relays it through Kafka.
# "outbox" is the application default. scripts/dev.py defaults local dev to
# kafka with the Compose broker at localhost:19092.
DOMAIN_EVENTS_DRIVER=kafka
DOMAIN_EVENTS_BATCH_SIZE=50
DOMAIN_EVENTS_POLL_INTERVAL_MS=500
DOMAIN_EVENTS_LOCK_TIMEOUT_MS=60000

KAFKA_BROKERS=localhost:19092
KAFKA_CLIENT_ID=thechat-worker
KAFKA_TOPIC=thechat.domain-events.v1
KAFKA_AUTO_CREATE_TOPICS=true
KAFKA_TOPIC_PARTITIONS=3
KAFKA_FROM_BEGINNING=true
KAFKA_CONSUMER_GROUP=thechat-message-events-v1
KAFKA_SSL=false
# Set all three SASL values together when the broker requires authentication.
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=
KAFKA_PORT=19092

REQUIRE_EMAIL_VERIFICATION=false

# Email (provider: "smtp" or "postmark")
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@thechat.app
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
POSTMARK_API_TOKEN=

# Backend

THECHAT_BACKEND_PORT=3000
THECHAT_BACKEND_URL=http://localhost:3000

# Rust tracing level (controls console/tokio-console output).
# Uses tracing's EnvFilter syntax: comma-separated `target=level` pairs.
# A bare level sets the default for all crates.
#
# Examples:
#   THECHAT_TRACING=thechat=trace                       # our code at trace, others at default
#   THECHAT_TRACING=thechat=debug,warn                  # our code at debug, everything else at warn
#   THECHAT_TRACING=thechat=trace,reqwest=info,warn     # per-crate control
#   THECHAT_TRACING=trace                               # everything at trace (very noisy — includes tokio, reqwest, hyper internals)
#
# Defaults: thechat=debug,info in dev builds, info in release builds
THECHAT_TRACING=thechat=debug,info

# Log file level (tauri-plugin-log). Filters both JS webview logs and Rust log
# records written to the platform log file.
# Accepted values: trace, debug, info, warn, error, off
# Defaults: debug in dev builds, info in release builds
THECHAT_LOG_LEVEL=debug

# API server log level (ElysiaJS/pino).
# Accepted values: trace, debug, info, warn, error, fatal, silent
# Default: info
LOG_LEVEL=info

# Directory Promtail scrapes for local dev logs (mounted into the promtail
# container by compose.yml; scripts/dev.py defaults it to .tmp/dev). Dev builds
# of the desktop app mirror their logs there as desktop.log so they show up in
# local Grafana.
# THECHAT_DEV_LOGS_DIR=.tmp/dev

# Local Grafana LGTM / OpenTelemetry export.
# Grafana: http://localhost:13300
GRAFANA_PORT=13300
OTEL_GRPC_PORT=14317
OTEL_HTTP_PORT=14318
THECHAT_OTEL_ENABLED=true
OTEL_SERVICE_NAMESPACE=thechat
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:14318
OTEL_EXPORTER_OTLP_TRACES_ENDPOINT=http://localhost:14318/v1/traces

# Rust/Tauri traces also need `pnpm tauri dev --features otel`.

# E2E tests
OPENROUTER_API_KEY=
