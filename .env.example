DATABASE_URL=postgresql://user:password@localhost:5432/thechat

REQUIRE_EMAIL_VERIFICATION=false

# Email (provider: "smtp" or "postmark")
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@thechat.app
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
POSTMARK_API_TOKEN=

# Backend

THECHAT_BACKEND_URL=http://localhost:3000

# Desktop app logging level (handled by Tauri log plugin)
# Accepted values: trace, debug, info, warn, error, off
# Defaults: debug in dev builds, info in release builds
THECHAT_LOG_LEVEL=debug
