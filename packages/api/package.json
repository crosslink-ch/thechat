{
  "name": "@thechat/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./async": "./src/async/index.ts",
    "./db": "./src/db/index.ts",
    "./db/schema": "./src/db/schema.ts",
    "./realtime": "./src/realtime.ts",
    "./test-helpers": "./src/test-helpers.ts"
  },
  "scripts": {
    "dev": "bun run --env-file ../../.env --watch src/index.ts",
    "dev:worker": "bun run --env-file ../../.env --watch src/scripts/worker.ts",
    "build": "bun build src/index.ts src/scripts/worker.ts --outdir dist --target bun",
    "start": "bun run --env-file ../../.env dist/index.js",
    "start:worker": "bun run --env-file ../../.env dist/scripts/worker.js",
    "worker": "bun run --env-file ../../.env src/scripts/worker.ts",
    "test": "bun test --env-file ../../.env",
    "db:generate": "bun run --env-file ../../.env drizzle-kit generate",
    "db:migrate": "bun run --env-file ../../.env drizzle-kit migrate",
    "db:push": "bun run --env-file ../../.env drizzle-kit push",
    "db:studio": "bun run --env-file ../../.env drizzle-kit studio"
  },
  "dependencies": {
    "@bogeychan/elysia-logger": "^0.1.10",
    "@elysiajs/cors": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@thechat/shared": "workspace:*",
    "bullmq": "^5.76.6",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.2.0",
    "elysia-mcp": "^0.1.1",
    "ioredis": "^5.10.1",
    "jose": "^6.1.3",
    "nodemailer": "^6.9.0",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/nodemailer": "^6.4.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "~5.8.3"
  }
}
