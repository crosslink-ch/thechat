{
  "name": "@thechat/api",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./db": "./src/db/index.ts",
    "./db/schema": "./src/db/schema.ts",
    "./test-helpers": "./src/test-helpers.ts"
  },
  "scripts": {
    "dev": "bun run --env-file ../../.env --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "start": "bun run --env-file ../../.env dist/index.js",
    "test": "bun test --env-file ../../.env",
    "test:e2e:openclaw-simulated": "OPENCLAW_E2E=1 bun test --env-file ../../.env --timeout 90000 src/e2e/openclaw-channel-simulated.test.ts",
    "db:generate": "bun run --env-file ../../.env drizzle-kit generate",
    "db:migrate": "bun run --env-file ../../.env drizzle-kit migrate",
    "db:push": "bun run --env-file ../../.env drizzle-kit push",
    "db:studio": "bun run --env-file ../../.env drizzle-kit studio"
  },
  "dependencies": {
    "@bogeychan/elysia-logger": "^0.1.10",
    "@elysiajs/cors": "^1.2.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@thechat/shared": "workspace:*",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.2.0",
    "elysia-mcp": "^0.1.1",
    "jose": "^6.1.3",
    "nodemailer": "^6.9.0",
    "postgres": "^3.4.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@thechat/openclaw-channel": "workspace:*",
    "@types/bun": "latest",
    "@types/nodemailer": "^6.4.0",
    "drizzle-kit": "^0.31.9",
    "typescript": "~5.8.3"
  }
}
