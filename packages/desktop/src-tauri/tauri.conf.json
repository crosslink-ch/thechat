{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "thechat",
  "version": "0.0.0-dev",
  "identifier": "com.bruno.thechat",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TheChat",
        "width": 1100,
        "height": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/node"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEM5M0RGQjhCRkIyQzgzREQKUldUZGd5ejdpL3M5eVFXZU5HSFpXUVlFV0JQRUxBNjE1dUJBNzQzOUcxbmt3QlZCTlFiYks2S3YK",
      "endpoints": [
        "https://github.com/crosslink-ch/thechat/releases/latest/download/latest.json"
      ]
    }
  }
}
