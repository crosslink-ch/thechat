{
  "name": "@thechat/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run --exclude '**/*.integration.test.ts' && INTEGRATION=true vitest run integration",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts'",
    "test:integration": "INTEGRATION=true vitest run integration",
    "test:watch": "vitest",
    "test:e2e": "wdio run e2e/wdio.conf.js",
    "test:e2e:headless": "env -u WAYLAND_DISPLAY GDK_BACKEND=x11 xvfb-run -a wdio run e2e/wdio.conf.js",
    "vitest": "vitest"
  },
  "dependencies": {
    "@elysiajs/eden": "^1.2.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-router": "^1.162.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-http": "^2",
    "@tauri-apps/plugin-log": "^2.8.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@thechat/shared": "workspace:*",
    "@tiptap/extension-mention": "^3.20.0",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/suggestion": "^3.20.0",
    "ajv": "^8.18.0",
    "highlight.js": "^11.11.1",
    "mitt": "^3.0.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sucrase": "^3.35.1",
    "tailwindcss": "^4.2.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.11"
